tail_log_excerpt() {
  local title="$1"
  local path="$2"
  if [[ -f "$path" ]]; then
    printf '[devctl] 最近日志 %s（%s）:\n' "$title" "$path" >&2
    tail -n 40 "$path" >&2 || true
  fi
}

extract_port_conflict_port() {
  local log_path="$1"
  local line=""
  [[ -f "$log_path" ]] || return 1

  while IFS= read -r line; do
    if [[ "$line" =~ Bind\ for\ .*:([0-9]+)\ failed:\ port\ is\ already\ allocated ]]; then
      printf '%s\n' "${BASH_REMATCH[1]}"
      return 0
    fi
  done <"$log_path"

  return 1
}

docker_published_port_owners() {
  local port="$1"
  docker_cmd ps -a --filter "publish=$port" --format '{{.Names}} {{.Ports}} {{.Status}}' 2>/dev/null || true
}

print_port_conflict_details() {
  local port="$1"
  local pid=""
  local owners=""

  STARTUP_FAILURE_HINT_OVERRIDE=""
  printf '[devctl] 详情: 端口冲突: Docker 无法绑定主机端口 %s\n' "$port" >&2

  pid="$(listener_pid "$port" 2>/dev/null || true)"
  if [[ -n "$pid" ]]; then
    printf '[devctl] 详情: 主机监听进程: %s\n' "$(pid_summary "$pid")" >&2
    STARTUP_FAILURE_HINT_OVERRIDE="停止占用端口 $port 的进程后重新运行 ./devctl up"
    return 0
  fi

  owners="$(docker_published_port_owners "$port")"
  if [[ -n "$owners" ]]; then
    printf '[devctl] 详情: 已有 Docker 容器占用端口 %s:\n' "$port" >&2
    while IFS= read -r owner; do
      [[ -n "$owner" ]] || continue
      printf '[devctl] 详情:   %s\n' "$owner" >&2
    done <<<"$owners"
    STARTUP_FAILURE_HINT_OVERRIDE="停止或删除已占用端口 $port 的容器后重新运行 ./devctl up"
    return 0
  fi

  printf '[devctl] 详情: 未在主机或发布的容器上找到占用端口 %s 的进程\n' "$port" >&2
  printf '[devctl] 详情: 通常是 Docker 本身留下的陈旧端口预留\n' >&2
  STARTUP_FAILURE_HINT_OVERRIDE="重启 Docker Desktop 清除端口 $port 的陈旧预留，然后重新运行 ./devctl up"
}

print_startup_failure_diagnostics() {
  local stage="$1"
  local log_path="$2"
  local port=""

  [[ "$stage" == "db" ]] || return 0
  port="$(extract_port_conflict_port "$log_path" 2>/dev/null || true)"
  [[ -n "$port" ]] || return 0

  print_port_conflict_details "$port"
}

report_startup_failure() {
  local stage="$1"
  local reason="$2"
  local log_title="$3"
  local log_path="$4"
  local hint="${5:-运行 ./devctl doctor}"

  stop_heartbeat 2>/dev/null || true
  STARTUP_FAILURE_HINT_OVERRIDE=""
  printf '[devctl] 启动失败于阶段: %s\n' "$stage" >&2
  printf '[devctl] 原因: %s\n' "$reason" >&2
  print_startup_failure_diagnostics "$stage" "$log_path"
  if [[ -n "$STARTUP_FAILURE_HINT_OVERRIDE" ]]; then
    hint="$STARTUP_FAILURE_HINT_OVERRIDE"
  fi
  tail_log_excerpt "$log_title" "$log_path"
  printf '提示: %s\n' "$hint" >&2
  exit 1
}

doctor_check_pid_file() {
  local check_name="$1"
  local pid_file="$2"
  local expected_substring="$3"
  local pid=""

  if [[ ! -f "$pid_file" ]]; then
    doctor_pass "$check_name" "无 pid 文件"
    return 0
  fi

  pid="$(read_pid_file "$pid_file")"
  if pid_matches_expected "$pid" "$expected_substring"; then
    doctor_pass "$check_name" "pid 文件指向一个存活的 $expected_substring 进程"
    return 0
  fi

  if [[ -n "$pid" ]] && pid_exists "$pid"; then
    doctor_warn "$check_name" "pid 文件指向了非预期的进程：$(pid_summary "$pid")"
  else
    doctor_warn "$check_name" "发现陈旧的 pid 文件：$pid_file"
  fi
  doctor_hint "若该进程已失效，请删除 $pid_file"
}

wait_for_mongo_ready() {
  local timeout_seconds="$1"
  local stage="${2:-}"
  local start_ts health elapsed_seconds last_report_seconds=-1
  start_ts="$(date +%s)"
  while true; do
    if docker_container_running "$MONGO_CONTAINER_NAME"; then
      health="$(docker_container_health "$MONGO_CONTAINER_NAME")"
      if [[ "$health" == "healthy" || "$health" == "running" ]]; then
        return 0
      fi
    else
      health="container=stopped"
    fi
    elapsed_seconds=$(( $(date +%s) - start_ts ))
    if (( elapsed_seconds >= timeout_seconds )); then
      return 1
    fi
    if [[ -n "$stage" ]] && progress_report_due "$elapsed_seconds" "$last_report_seconds"; then
      log_waiting_status "$stage" "mongo 健康=${health:-unknown}" "$elapsed_seconds" "$timeout_seconds"
      last_report_seconds="$elapsed_seconds"
    fi
    sleep 1
  done
}

wait_for_scan_container() {
  local timeout_seconds="$1"
  local stage="${2:-}"
  local start_ts elapsed_seconds last_report_seconds=-1
  start_ts="$(date +%s)"
  while true; do
    if docker_container_running "$SCAN_CONTAINER_NAME"; then
      return 0
    fi
    elapsed_seconds=$(( $(date +%s) - start_ts ))
    if (( elapsed_seconds >= timeout_seconds )); then
      return 1
    fi
    if [[ -n "$stage" ]] && progress_report_due "$elapsed_seconds" "$last_report_seconds"; then
      log_waiting_status "$stage" "容器 $SCAN_CONTAINER_NAME 尚未运行" "$elapsed_seconds" "$timeout_seconds"
      last_report_seconds="$elapsed_seconds"
    fi
    sleep 1
  done
}

run_doctor() {
  local api_port ui_port redis_port
  local docker_compose_ok=0
  local docker_daemon_ok=0
  local db_state="unknown"
  local server_state ui_state scan_state

  DOCTOR_FAIL_COUNT=0
  api_port="$(url_port "$API_URL" 8080)"
  ui_port="$(url_port "$UI_URL" 4000)"
  redis_port="${SCAN_REDIS_PORT:-6379}"

  doctor_check_repo_layout
  doctor_check_path "server_env" "$SERVER_ENV_FILE" "file" "fail" "运行 ./devctl install 以生成 ScopeSentry/.env"
  doctor_check_path "local_dev_runtime" "$LOCAL_DEV_DIR" "dir" "warn" "运行 ./devctl install 以准备 .local-dev 目录"
  doctor_check_scan_network_mode

  doctor_check_command "docker_cli" "$DOCKER_BIN" "请安装 Docker Desktop 或兼容的 docker 引擎"
  doctor_check_command "go_cli" "$GO_BIN" "请先安装 Go 后再构建本地后端"
  doctor_check_command "pnpm_cli" "$PNPM_BIN" "请先安装 pnpm 后再启动 UI"
  doctor_check_command "python3_cli" "$PYTHON_BIN" "请安装 Python 3 用于辅助脚本与清单生成"
  doctor_check_command "curl_cli" "$CURL_BIN" "请安装 curl 用于就绪探测"

  if command_exists "$DOCKER_BIN"; then
    if docker_cmd compose version >/dev/null 2>&1; then
      docker_compose_ok=1
      doctor_pass "docker_compose" "docker compose 可用"
    else
      doctor_fail "docker_compose" "docker compose 不可用"
      doctor_hint "请安装或启用 docker compose 后重新运行 ./devctl doctor"
    fi

    if docker_daemon_reachable; then
      docker_daemon_ok=1
      doctor_pass "docker_daemon" "docker 守护进程可达"
    else
      doctor_fail "docker_daemon" "docker 守护进程不可达"
      doctor_hint "启动 Docker 后重新运行 ./devctl doctor"
    fi
  fi

  doctor_check_port "api_port" "$api_port" "scope-sentry-dev" "请释放端口 ${api_port}，或在运行 ./devctl up 前覆盖 API_URL"
  doctor_check_port "ui_port" "$ui_port" "vite" "请释放端口 ${ui_port}，或在运行 ./devctl up 前覆盖 UI_URL"
  doctor_check_port "redis_port" "$redis_port" "" "如果 MongoDB 与 Redis 需要本地绑定，请释放端口 $redis_port" "$REDIS_CONTAINER_NAME"

  doctor_check_pid_file "server_pid" "$SERVER_PID_FILE" "scope-sentry-dev"
  doctor_check_pid_file "ui_pid" "$UI_PID_FILE" "pnpm"

  if [[ "$docker_daemon_ok" == "1" && "$docker_compose_ok" == "1" ]]; then
    db_state="$(db_status)"
    scan_state="$(scan_status)"
    doctor_pass "db_status" "当前状态：$db_state"
    doctor_pass "scan_status" "当前状态：$scan_state"
  else
    doctor_warn "db_status" "因 docker 诊断失败，已跳过"
    doctor_warn "scan_status" "因 docker 诊断失败，已跳过"
  fi

  server_state="$(server_status)"
  ui_state="$(ui_status)"
  doctor_pass "server_status" "当前状态：$server_state"
  doctor_pass "ui_status" "当前状态：$ui_state"

  if [[ -f "$PASSWORD_FILE" ]]; then
    doctor_pass "password_file" "已就位：$PASSWORD_FILE"
  else
    doctor_warn "password_file" "尚未生成：$PASSWORD_FILE"
    doctor_hint "如数据库已初始化但忘记密码，请运行 ./devctl reset-password <new-password>"
  fi

  if (( DOCTOR_FAIL_COUNT > 0 )); then
    return 1
  fi
}

