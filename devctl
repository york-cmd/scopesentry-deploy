log_waiting_status() {
  local stage="$1"
  local message="$2"
  local elapsed_seconds="$3"
  local timeout_seconds="$4"
  log "等待 ${stage}: ${message}，已用时 ${elapsed_seconds}s（上限 ${timeout_seconds}s）"
}

progress_report_due() {
  local elapsed_seconds="$1"
  local last_report_seconds="$2"
  if (( last_report_seconds < 0 )); then
    return 0
  fi
  (( elapsed_seconds - last_report_seconds >= DEVCTL_PROGRESS_INTERVAL ))
}

# ---- 心跳：为长时间静默操作（docker compose、go build、pnpm install）提供进度反馈 ----
HEARTBEAT_PID=""

start_heartbeat() {
  local label="$1"
  local start_ts
  start_ts="$(date +%s)"
  (
    while :; do
      sleep "$DEVCTL_PROGRESS_INTERVAL"
      printf '[devctl] 仍在%s，已用时 %ds\n' "$label" "$(( $(date +%s) - start_ts ))"
    done
  ) &
  HEARTBEAT_PID=$!
  disown "$HEARTBEAT_PID" 2>/dev/null || true
}

stop_heartbeat() {
  [[ -n "${HEARTBEAT_PID:-}" ]] || return 0
  kill "$HEARTBEAT_PID" 2>/dev/null || true
  wait "$HEARTBEAT_PID" 2>/dev/null || true
  HEARTBEAT_PID=""
}

# ---- 日志轮转：保留最近一次失败的上下文 ----
rotate_log() {
  local log_path="$1"
  if [[ -f "$log_path" ]]; then
    mv -f "$log_path" "${log_path}.1" 2>/dev/null || : >"$log_path"
  fi
}

# ---- 等待文件出现（替代魔法 sleep）----
wait_for_file() {
  local path="$1"
  local timeout_seconds="$2"
  local stage="${3:-}"
  local start_ts elapsed last_report_seconds=-1
  start_ts="$(date +%s)"
  while true; do
    [[ -f "$path" ]] && return 0
    elapsed=$(( $(date +%s) - start_ts ))
    if (( elapsed >= timeout_seconds )); then
      return 1
    fi
    if [[ -n "$stage" ]] && progress_report_due "$elapsed" "$last_report_seconds"; then
      log_waiting_status "$stage" "文件 $path 尚未生成" "$elapsed" "$timeout_seconds"
      last_report_seconds="$elapsed"
    fi
    sleep 1
  done
}

fail() {
  stop_heartbeat 2>/dev/null || true
  printf '[devctl] 错误: %s\n' "$*" >&2
  exit 1
}

# 退出前兜底清理心跳进程，避免 set -e 异常退出时留下后台循环
trap 'stop_heartbeat 2>/dev/null || true' EXIT

