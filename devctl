  local fingerprint entry_asset
  fingerprint="$(server_static_fingerprint)" || return 1
  entry_asset="$(server_static_entry_asset)" || return 1
  write_server_embed_meta "$fingerprint" "$entry_asset"
}

server_rebuild_reason() {
  local current_fingerprint current_entry_asset

  [[ -f "$SERVER_BINARY" ]] || {
    printf '缺失后端二进制'
    return 0
  }
  [[ -d "$SERVER_STATIC_DIR" ]] || {
    printf '缺失嵌入前端静态目录'
    return 0
  }
  [[ -f "$SERVER_STATIC_DIR/index.html" ]] || {
    printf '缺失嵌入前端 index.html'
    return 0
  }

  current_fingerprint="$(server_static_fingerprint 2>/dev/null || true)"
  current_entry_asset="$(server_static_entry_asset 2>/dev/null || true)"
  if [[ -z "$current_fingerprint" || -z "$current_entry_asset" ]]; then
    printf '无法读取嵌入前端静态资源指纹'
    return 0
  fi

  [[ -f "$SERVER_EMBED_META_FILE" ]] || {
    printf '缺少嵌入前端构建记录'
    return 0
  }

  load_server_embed_meta
  if [[ -z "$SERVER_EMBED_STATIC_FINGERPRINT" || -z "$SERVER_EMBED_ENTRY_ASSET" ]]; then
    printf '嵌入前端构建记录不完整'
    return 0
  fi
  if [[ "$current_fingerprint" != "$SERVER_EMBED_STATIC_FINGERPRINT" ]]; then
    printf '检测到嵌入前端静态资源变更'
    return 0
  fi
  if [[ "$current_entry_asset" != "$SERVER_EMBED_ENTRY_ASSET" ]]; then
    printf '检测到嵌入前端入口资源变更'
    return 0
  fi

  return 1
}

port_listening() {
  local host="$1"
  local port="$2"
  local test_marker=""
  if [[ -n "${DEVCTL_TEST_STATE_DIR:-}" ]]; then
    test_marker="$DEVCTL_TEST_STATE_DIR/tcp-${host}-${port}.ready"
    [[ -f "$test_marker" ]] && return 0
  fi
  "$PYTHON_BIN" - "$host" "$port" <<'PY'
import socket
import sys

host = sys.argv[1]
port = int(sys.argv[2])
sock = socket.socket()
sock.settimeout(1.0)
try:
    sock.connect((host, port))
except OSError:
    sys.exit(1)
finally:
    sock.close()
PY
}

wait_for_tcp_port() {
  local host="$1"
  local port="$2"
  local timeout_seconds="$3"
  local stage="${4:-}"
  local start_ts elapsed_seconds last_report_seconds=-1
  start_ts="$(date +%s)"

  while true; do
    if port_listening "$host" "$port"; then
      return 0
    fi
    elapsed_seconds=$(( $(date +%s) - start_ts ))
    if (( elapsed_seconds >= timeout_seconds )); then
      return 1
    fi
    if [[ -n "$stage" ]] && progress_report_due "$elapsed_seconds" "$last_report_seconds"; then
      log_waiting_status "$stage" "tcp ${host}:${port} 尚未可达" "$elapsed_seconds" "$timeout_seconds"
      last_report_seconds="$elapsed_seconds"
    fi
    sleep 1
  done
}

http_ok() {
  local url="$1"
  "$CURL_BIN" -fsS --max-time 2 "$url" >/dev/null 2>&1
}

http_get_body() {
  local url="$1"
  "$CURL_BIN" -fsS --max-time 5 "$url"
}

verify_server_embedded_ui_consistent() {
  local url="$1"
  local root_url="${url%/}/"
  local expected_entry actual_entry html

  expected_entry="$(server_static_entry_asset 2>/dev/null || true)"
  if [[ -z "$expected_entry" ]]; then
    printf '无法解析磁盘静态资源入口'
    return 1
  fi

  html="$(http_get_body "$root_url" 2>/dev/null || true)"
  if [[ -z "$html" ]]; then
    printf '无法读取 %s 返回的前端 HTML' "$root_url"
    return 1
  fi

  actual_entry="$(printf '%s' "$html" | extract_entry_asset_from_html 2>/dev/null || true)"
  if [[ -z "$actual_entry" ]]; then
    printf '无法解析 %s 返回的前端入口资源' "$root_url"
    return 1
  fi
  if [[ "$actual_entry" != "$expected_entry" ]]; then
    printf '后端返回的嵌入前端入口与磁盘静态资源不一致: expected=%s actual=%s' "$expected_entry" "$actual_entry"
    return 1
  fi

  return 0
}

wait_for_http() {
  local url="$1"
  local timeout_seconds="$2"
  local stage="${3:-}"
  local pid_file="${4:-}"
  local expected_process="${5:-}"
  local start_ts elapsed_seconds last_report_seconds=-1
  local pid=""
  start_ts="$(date +%s)"

  while true; do
    if http_ok "$url"; then
      return 0
    fi
    if [[ -n "$pid_file" ]]; then
      pid="$(read_pid_file "$pid_file")"
      if [[ -n "$pid" ]] && ! pid_matches_expected "$pid" "$expected_process"; then
        return 2
      fi
    fi
    elapsed_seconds=$(( $(date +%s) - start_ts ))
    if (( elapsed_seconds >= timeout_seconds )); then
      return 1
    fi
    if [[ -n "$stage" ]] && progress_report_due "$elapsed_seconds" "$last_report_seconds"; then
      log_waiting_status "$stage" "HTTP $url 尚未就绪" "$elapsed_seconds" "$timeout_seconds"
      last_report_seconds="$elapsed_seconds"
    fi
    sleep 1
  done
}

listener_pid() {
  local port="$1"
  local pid=""
  if ! command_exists "$LSOF_BIN"; then
    return 1
  fi
  if IFS= read -r pid < <("$LSOF_BIN" -tiTCP:"$port" -sTCP:LISTEN 2>/dev/null); then
    [[ -n "$pid" ]] || return 1
    printf '%s\n' "$pid"
    return 0
  fi
  return 1
}

pid_summary() {
  local pid="$1"
  local command=""
  command="$(pid_command "$pid")"
  if [[ -n "$command" ]]; then
    printf '%s (pid %s)\n' "$command" "$pid"
  else
    printf 'pid %s\n' "$pid"
  fi
}

doctor_check_port() {
  local check_name="$1"
  local port="$2"
  local expected_substring="${3:-}"
  local hint="${4:-}"
  local expected_container="${5:-}"
  local pid=""

  if ! command_exists "$LSOF_BIN"; then
    doctor_warn "$check_name" "未安装 lsof，跳过端口 $port 的检查"
    return 0
  fi

  pid="$(listener_pid "$port" 2>/dev/null || true)"
  if [[ -z "$pid" ]]; then
    doctor_pass "$check_name" "端口 $port 空闲"
    return 0
  fi

  if [[ -n "$expected_substring" ]] && pid_matches_expected "$pid" "$expected_substring"; then
    doctor_pass "$check_name" "端口 $port 由预期进程占用"
    return 0
  fi

  if [[ -n "$expected_container" ]] && docker_container_publishes_port "$expected_container" "$port"; then
    doctor_pass "$check_name" "端口 $port 由本项目容器 $expected_container 发布"
    return 0
  fi

  doctor_warn "$check_name" "端口 $port 已被占用：$(pid_summary "$pid")"
  [[ -n "$hint" ]] && doctor_hint "$hint"
}

find_pid_by_command() {
  local expected="$1"
  local pid=""
  if ! command_exists "$PGREP_BIN"; then
    return 1
  fi
  if IFS= read -r pid < <("$PGREP_BIN" -f "$expected" 2>/dev/null); then
    [[ -n "$pid" ]] || return 1
    printf '%s\n' "$pid"
    return 0
  fi
  return 1
}

kill_pid_gracefully() {
  local pid="$1"
  local timeout_seconds="${2:-10}"
  local start_ts

  pid_exists "$pid" || return 0
  kill "$pid" >/dev/null 2>&1 || true
  start_ts="$(date +%s)"
  while pid_exists "$pid"; do
    if (( $(date +%s) - start_ts >= timeout_seconds )); then
      kill -9 "$pid" >/dev/null 2>&1 || true
      break
    fi
    sleep 1
  done
}

stop_local_process_by_port_or_pid() {
  local pid_file="$1"
  local expected_substring="$2"
  local port="${3:-}"
  local use_pgrep_fallback="${4:-0}"
  local pid=""
  local listen_pid=""
  local matched_pid=""

  pid="$(read_pid_file "$pid_file")"
  if pid_matches_expected "$pid" "$expected_substring"; then
    kill_pid_gracefully "$pid"
  fi

  if [[ -n "$port" ]] && listen_pid="$(listener_pid "$port" 2>/dev/null || true)"; then
    if pid_matches_expected "$listen_pid" "$expected_substring"; then
      kill_pid_gracefully "$listen_pid"
    fi
  fi

  # pgrep fallback 非常宽泛（例如 "pnpm" 会误杀其它项目的 pnpm dev），
  # 默认关闭，仅对名称足够唯一的进程（例如 scope-sentry-dev 二进制）开启。
  if [[ "$use_pgrep_fallback" == "1" ]]; then
    if matched_pid="$(find_pid_by_command "$expected_substring" 2>/dev/null || true)"; then
      if pid_matches_expected "$matched_pid" "$expected_substring"; then
        kill_pid_gracefully "$matched_pid"
      fi
    fi
  fi

  rm -f "$pid_file"
}

