  doctor_result "WARN" "$1" "$2"
}

doctor_fail() {
  local check_name="$1"
  local summary="$2"
  DOCTOR_FAIL_COUNT=$((DOCTOR_FAIL_COUNT + 1))
  doctor_result "FAIL" "$check_name" "$summary"
}

doctor_hint() {
  printf '提示: %s\n' "$1"
}

doctor_check_command() {
  local check_name="$1"
  local cmd="$2"
  local hint="${3:-}"
  if command_exists "$cmd"; then
    doctor_pass "$check_name" "已找到 ${cmd}：$(command -v "$cmd")"
  else
    doctor_fail "$check_name" "未找到 $cmd"
    [[ -n "$hint" ]] && doctor_hint "$hint"
  fi
}

doctor_check_repo_layout() {
  local -a missing=()

  [[ -d "$SERVER_DIR" ]] || missing+=("$SERVER_DIR")
  [[ -d "$UI_DIR" ]] || missing+=("$UI_DIR")
  [[ -d "$SCAN_DIR" ]] || missing+=("$SCAN_DIR")
