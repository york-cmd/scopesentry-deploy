reset_local_web_password() {
  local new_password="$1"
  local password_hash eval_js
  [[ -n "$new_password" ]] || fail "用法: ./devctl reset-password <new-password>"

  ensure_local_dirs
  load_server_env_values
  if ! docker_container_running "$MONGO_CONTAINER_NAME"; then
    fail "mongodb 容器未运行，请先运行 ./devctl up 或 ./devctl install 后启动数据库"
  fi

  password_hash="$(sha256_hex "$new_password")"
  eval_js="db.getSiblingDB(\"$SERVER_MONGODB_DATABASE_VALUE\").user.updateOne({username:\"ScopeSentry\"}, {\$set:{password:\"$password_hash\", updated_at:new Date()}})"

  docker_cmd exec "$MONGO_CONTAINER_NAME" mongosh --quiet \
    -u "$SERVER_MONGODB_USER_VALUE" \
    -p "$SERVER_MONGODB_PASSWORD_VALUE" \
    --authenticationDatabase admin \
    --eval "$eval_js" >/dev/null \
    || fail "本地密码重置失败"

  printf '%s' "$new_password" >"$PASSWORD_FILE"
  log "本地 Web 密码已重置"
  log "Web 用户: ScopeSentry"
  log "Web 密码: $new_password"
  log "密码文件: $PASSWORD_FILE"
}

start_scan() {
  ensure_local_dirs
  rotate_log "$SCAN_LOG"
  scan_compose up -d >"$SCAN_LOG" 2>&1
}

stop_scan() {
  if [[ "$(scan_status)" == "stopped" ]]; then
    return 0
  fi

  scan_compose down --remove-orphans >>"$SCAN_LOG" 2>&1 || true
  if docker_container_running "$SCAN_CONTAINER_NAME"; then
    docker_cmd rm -f "$SCAN_CONTAINER_NAME" >>"$SCAN_LOG" 2>&1 || true
  fi
  if docker_container_running "$SCAN_CONTAINER_NAME"; then
    fail "scan 容器仍在运行: $SCAN_CONTAINER_NAME"
  fi
}

stop_db() {
  if [[ "$(db_status)" == "stopped" ]]; then
    return 0
  fi

  db_compose stop mongodb redis >>"$DB_LOG" 2>&1 || true
  if docker_container_running "$MONGO_CONTAINER_NAME"; then
    docker_cmd rm -f "$MONGO_CONTAINER_NAME" >>"$DB_LOG" 2>&1 || true
  fi
  if docker_container_running "$REDIS_CONTAINER_NAME"; then
    docker_cmd rm -f "$REDIS_CONTAINER_NAME" >>"$DB_LOG" 2>&1 || true
  fi

  if docker_container_running "$MONGO_CONTAINER_NAME"; then
    fail "mongodb 容器仍在运行"
  fi
  if docker_container_running "$REDIS_CONTAINER_NAME"; then
    fail "redis 容器仍在运行"
  fi
}

status_cn() {
  case "$1" in
    running) printf '运行中' ;;
    stopped) printf '已停止' ;;
    starting) printf '启动中' ;;
    partial) printf '部分运行' ;;
    *) printf '%s' "$1" ;;
  esac
}

password_status_cn() {
  case "$(password_status)" in
    present) printf '已生成' ;;
    pending) printf '待生成' ;;
    *) printf '未知' ;;
  esac
}

print_status() {
  refresh_manifest
  printf '配置: %s\n' "$PROFILE_NAME"
  printf 'API 地址: %s\n' "$API_URL"
  printf 'UI 地址: %s\n' "$UI_URL"
  printf '节点名: %s\n' "$NODE_NAME"
  printf 'Scan 镜像: %s\n' "$SCAN_IMAGE"
  printf '密码文件: %s (%s)\n' "$PASSWORD_FILE" "$(password_status_cn)"
  printf 'DB: %s\n' "$(status_cn "$(db_status)")"
  printf '后端: %s\n' "$(status_cn "$(server_status)")"
  printf 'UI 服务: %s\n' "$(status_cn "$(ui_status)")"
  printf '扫描端: %s\n' "$(status_cn "$(scan_status)")"
  printf '清单文件: %s\n' "$MANIFEST_FILE"
}

on_up_interrupted() {
  stop_heartbeat
  printf '[devctl] 收到中断信号，正在回滚已启动的组件...\n' >&2
  run_down >/dev/null 2>&1 || true
  printf '[devctl] 回滚完成\n' >&2
  exit 130
}

run_up() {
  local redis_port server_port ui_port
  redis_port="${SCAN_REDIS_PORT:-6379}"
  server_port="$(url_port "$API_URL" 8080)"
  ui_port="$(url_port "$UI_URL" 4000)"

  trap on_up_interrupted INT TERM

  run_install 0 >/dev/null
  stage_set_total 4

  # ---- [1/4] DB ----
  stage_begin "db" "启动数据库（mongodb/redis）"
  start_heartbeat "启动 mongodb/redis"
  local db_rc=0
  start_db || db_rc=$?
  stop_heartbeat
  if (( db_rc != 0 )); then
    refresh_manifest
    report_startup_failure "db" "docker compose 无法启动 mongodb/redis" "db" "$DB_LOG"
  fi

  wait_for_mongo_ready 90 "db" || {
    refresh_manifest
    report_startup_failure "db" "mongodb 未在后端启动前就绪" "db" "$DB_LOG"
  }

  wait_for_tcp_port 127.0.0.1 "$redis_port" 30 "db" || {
    refresh_manifest
    report_startup_failure "db" "redis 端口 $redis_port 不可达" "db" "$DB_LOG"
  }
  stage_end "db"

  # ---- [2/4] Server ----
  stage_begin "server" "编译并启动后端"
  if ! start_server; then
    refresh_manifest
    report_startup_failure "server" "后端进程在就绪检查完成前失败" "server" "$SERVER_LOG"
  fi
  if wait_for_http "$API_URL" 60 "server" "$SERVER_PID_FILE" "scope-sentry-dev"; then
    :
  else
    local wait_status=$?
    refresh_manifest
    if [[ "$wait_status" == "2" ]]; then
      report_startup_failure "server" "后端进程在就绪检查完成前退出" "server" "$SERVER_LOG"
    fi
    report_startup_failure "server" "后端未能在 $API_URL 就绪" "server" "$SERVER_LOG"
  fi
  local embedded_ui_error=""
  if embedded_ui_error="$(verify_server_embedded_ui_consistent "$API_URL")"; then
    :
  else
    printf '%s\n' "$embedded_ui_error" >>"$SERVER_LOG"
    stop_local_process_by_port_or_pid "$SERVER_PID_FILE" "scope-sentry-dev" "$(url_port "$API_URL" 8080)" 1
    refresh_manifest
    report_startup_failure "server" "$embedded_ui_error" "server" "$SERVER_LOG"
  fi
  wait_for_file "$PASSWORD_FILE" 30 "server" \
    || log "警告: 密码文件仍未生成（${PASSWORD_FILE}），请查看 $SERVER_LOG"
  stage_end "server"

  # ---- [3/4] UI ----
  stage_begin "ui" "启动 pnpm dev"
  if ! start_ui; then
    refresh_manifest
    report_startup_failure "ui" "UI 进程在就绪检查完成前失败" "ui" "$UI_LOG"
  fi
  if wait_for_http "$UI_URL" 60 "ui" "$UI_PID_FILE" "pnpm"; then
    :
  else
    local wait_status=$?
    refresh_manifest
    if [[ "$wait_status" == "2" ]]; then
      report_startup_failure "ui" "UI 进程在就绪检查完成前退出" "ui" "$UI_LOG"
    fi
    report_startup_failure "ui" "UI 未能在 $UI_URL 就绪" "ui" "$UI_LOG"
  fi
  stage_end "ui"

  # ---- [4/4] Scan ----
  stage_begin "scan" "启动扫描容器"
  if ! ensure_selected_scan_image_available; then
    refresh_manifest
    report_startup_failure "scan" "scan 镜像准备失败" "scan" "$SCAN_LOG" "运行 ./devctl scan rebuild"
  fi
  start_heartbeat "启动扫描容器"
  local scan_rc=0
  start_scan || scan_rc=$?
  stop_heartbeat
  if (( scan_rc != 0 )); then
    refresh_manifest
    report_startup_failure "scan" "scan 容器在 docker compose 启动期间失败" "scan" "$SCAN_LOG"
  fi
  wait_for_scan_container 30 "scan" || {
    refresh_manifest
    report_startup_failure "scan" "scan 容器未就绪" "scan" "$SCAN_LOG"
  }
  stage_end "scan"

  trap - INT TERM
  refresh_manifest
  print_status
}

run_down() {
  local server_port ui_port
  server_port="$(url_port "$API_URL" 8080)"
  ui_port="$(url_port "$UI_URL" 4000)"

  ensure_local_dirs
  stage_set_total 4

  stage_begin "server" "停止后端进程"
  # scope-sentry-dev 是自建二进制，名字唯一，保留 pgrep 兜底
  stop_local_process_by_port_or_pid "$SERVER_PID_FILE" "scope-sentry-dev" "$server_port" 1
  stage_end "server"

  stage_begin "ui" "停止 UI（pnpm dev）"
  # pnpm 太宽泛，关闭 pgrep 兜底，避免误杀其他项目的 pnpm 进程
  stop_local_process_by_port_or_pid "$UI_PID_FILE" "pnpm" "$ui_port" 0
  stage_end "ui"

  stage_begin "scan" "停止扫描容器"
  stop_scan
  stage_end "scan"

  stage_begin "db" "停止数据库容器"
  stop_db
  stage_end "db"

  refresh_manifest

  [[ "$(server_status)" == "stopped" ]] || fail "后端进程仍在运行"
  [[ "$(ui_status)" == "stopped" ]] || fail "UI 进程仍在运行"
  [[ "$(scan_status)" == "stopped" ]] || fail "scan 容器仍在运行"
  [[ "$(db_status)" == "stopped" ]] || fail "数据库容器仍在运行"
  log "全部服务已停止"
}

build_scan_binary() {
  # 在宿主机交叉编译 Linux amd64 Go 二进制到 $SCAN_DIST_BINARY。
  # 结果由 compose override bind-mount 进容器，不再 COPY 到镜像里。
  local go_cache_dir go_mod_cache_dir go_proxy_value
  go_cache_dir="$CACHE_DIR/go-build/scope-scan-docker-image"
  go_mod_cache_dir="$CACHE_DIR/go-mod"
  go_proxy_value="${GO_PROXY_URL:-${GOPROXY:-https://proxy.golang.org,direct}}"

  mkdir -p "$go_cache_dir" "$go_mod_cache_dir" "$SCAN_DIST_DIR"

  local rc=0
  (
    cd "$SCAN_DIR"
    GOCACHE="$go_cache_dir" \
    GOMODCACHE="$go_mod_cache_dir" \
    GOPROXY="$go_proxy_value" \
    CGO_ENABLED=0 \
    GOOS=linux \
    GOARCH=amd64 \
    "$GO_BIN" build -o "$SCAN_DIST_BINARY" ./cmd/ScopeSentry/main.go
  ) >>"$SCAN_LOG" 2>&1 || rc=$?
  return "$rc"
}

ensure_oneforall_archive() {
  local archive_dir archive_path archive_tmp archive_url
  archive_dir="$SCAN_DIR/third_party"
  archive_path="$archive_dir/oneforall.tar.gz"
  archive_tmp="$archive_path.tmp"
  archive_url="${ONEFORALL_ARCHIVE_URL:-https://github.com/shmilylty/OneForAll/archive/refs/heads/master.tar.gz}"

  if [[ -s "$archive_path" ]]; then
    return 0
  fi

  command_exists "$CURL_BIN" || fail "缺少 curl，无法下载 OneForAll 源码包"
  mkdir -p "$archive_dir"
  log "下载 OneForAll 源码包: $archive_url"
  "$CURL_BIN" -fsSL "$archive_url" -o "$archive_tmp" || {
    rm -f "$archive_tmp"
    fail "OneForAll 源码包下载失败: $archive_url"
  }
  mv -f "$archive_tmp" "$archive_path"
}

build_local_scan_base_image() {
  # 重度依赖层（chromium、puredns/massdns、apt 包、字体、tz）。构建慢但很少重建。
  mkdir -p "$SCAN_DIST_DIR"
  local attempt rc apt_mirror apt_security_mirror pip_index_url
  apt_mirror="${SCAN_APT_MIRROR:-https://mirrors.aliyun.com/debian}"
  apt_security_mirror="${SCAN_APT_SECURITY_MIRROR:-https://mirrors.aliyun.com/debian-security}"
  pip_index_url="${SCAN_PIP_INDEX_URL:-https://mirrors.aliyun.com/pypi/simple}"
  for (( attempt = 1; attempt <= DEVCTL_SCAN_BUILD_RETRIES; attempt++ )); do
    log "scan base 镜像构建尝试 ${attempt}/${DEVCTL_SCAN_BUILD_RETRIES}"
    printf '\n[devctl] scan base 镜像构建尝试 %s/%s\n' \
      "$attempt" "$DEVCTL_SCAN_BUILD_RETRIES" >>"$SCAN_LOG"
    printf '[devctl] scan base 构建源: apt=%s security=%s pip=%s\n' \
      "$apt_mirror" "$apt_security_mirror" "$pip_index_url" >>"$SCAN_LOG"

    start_heartbeat "构建 scan base 镜像（尝试 ${attempt}/${DEVCTL_SCAN_BUILD_RETRIES}）"
    rc=0
    (
      cd "$SCAN_DIR"
      DOCKER_BUILDKIT=1 \
      "$DOCKER_BIN" build \
        -f "$SCAN_BASE_DOCKERFILE" \
        --build-arg "APT_MIRROR=$apt_mirror" \
        --build-arg "APT_SECURITY_MIRROR=$apt_security_mirror" \
        --build-arg "PIP_INDEX_URL=$pip_index_url" \
        -t "$LOCAL_SCAN_BASE_IMAGE" .
    ) >>"$SCAN_LOG" 2>&1 || rc=$?
    stop_heartbeat

    if (( rc == 0 )); then
      return 0
    fi

    if (( attempt < DEVCTL_SCAN_BUILD_RETRIES )); then
      log "scan base 镜像构建失败（${attempt}/${DEVCTL_SCAN_BUILD_RETRIES}），${DEVCTL_SCAN_BUILD_RETRY_DELAY}s 后重试"
      sleep "$DEVCTL_SCAN_BUILD_RETRY_DELAY"
      continue
    fi

    log "scan base 镜像构建失败（${attempt}/${DEVCTL_SCAN_BUILD_RETRIES}），已达最大重试次数"
    return 1
  done
}

scan_app_build_base_image() {
  if docker_image_exists "$LOCAL_SCAN_BASE_IMAGE"; then
    printf '%s' "$LOCAL_SCAN_BASE_IMAGE"
    return 0
  fi
  if docker_image_exists "$LOCAL_SCAN_IMAGE"; then
    printf '%s' "$LOCAL_SCAN_IMAGE"
    return 0
  fi
  return 1
}

build_local_scan_image() {
  # App 层（tools/linux/* + 解析器文件）。轻量、~10-20s。
  # 优先基于 base 镜像；base 缺失但 app 镜像存在时可复用 app 镜像叠加一层。
  mkdir -p "$SCAN_DIST_DIR"
  local attempt rc pip_index_url oneforall_archive_url scan_base_image
  pip_index_url="${SCAN_PIP_INDEX_URL:-https://mirrors.aliyun.com/pypi/simple}"
  oneforall_archive_url="${ONEFORALL_ARCHIVE_URL:-https://github.com/shmilylty/OneForAll/archive/refs/heads/master.tar.gz}"
  ensure_oneforall_archive
  scan_base_image="$(scan_app_build_base_image)" || {
    log "未找到 scan base/app 镜像，开始构建 base 镜像"
    ensure_scan_base_image_available || return $?
    scan_base_image="$LOCAL_SCAN_BASE_IMAGE"
  }
  if [[ "$scan_base_image" == "$LOCAL_SCAN_IMAGE" ]]; then
    log "scan base 镜像缺失，复用现有 app 镜像 ${LOCAL_SCAN_IMAGE} 作为构建底座"
  fi
  for (( attempt = 1; attempt <= DEVCTL_SCAN_BUILD_RETRIES; attempt++ )); do
    log "scan 镜像构建尝试 ${attempt}/${DEVCTL_SCAN_BUILD_RETRIES}"
    printf '\n[devctl] scan 镜像构建尝试 %s/%s\n' "$attempt" "$DEVCTL_SCAN_BUILD_RETRIES" >>"$SCAN_LOG"
    printf '[devctl] scan 构建源: oneforall=%s pip=%s\n' \
      "$oneforall_archive_url" "$pip_index_url" >>"$SCAN_LOG"

    start_heartbeat "构建 scan 镜像（尝试 ${attempt}/${DEVCTL_SCAN_BUILD_RETRIES}）"
    rc=0
    (
      cd "$SCAN_DIR"
      DOCKER_BUILDKIT=1 \
      "$DOCKER_BIN" build \
        -f "$SCAN_APP_DOCKERFILE" \
        --build-arg "SCAN_BASE_IMAGE=$scan_base_image" \
        --build-arg "ONEFORALL_ARCHIVE=third_party/oneforall.tar.gz" \
        --build-arg "PIP_INDEX_URL=$pip_index_url" \
        -t "$LOCAL_SCAN_IMAGE" .
    ) >>"$SCAN_LOG" 2>&1 || rc=$?
    stop_heartbeat

    if (( rc == 0 )); then
      SCAN_IMAGE="$LOCAL_SCAN_IMAGE"
      return 0
    fi

    if (( attempt < DEVCTL_SCAN_BUILD_RETRIES )); then
      log "scan 镜像构建失败（${attempt}/${DEVCTL_SCAN_BUILD_RETRIES}），${DEVCTL_SCAN_BUILD_RETRY_DELAY}s 后重试"
      sleep "$DEVCTL_SCAN_BUILD_RETRY_DELAY"
      continue
    fi

    log "scan 镜像构建失败（${attempt}/${DEVCTL_SCAN_BUILD_RETRIES}），已达最大重试次数"
    return 1
  done

  SCAN_IMAGE="$LOCAL_SCAN_IMAGE"
}

ensure_scan_base_image_available() {
  if docker_image_exists "$LOCAL_SCAN_BASE_IMAGE"; then
    return 0
  fi
  log "未找到 scan base 镜像 ${LOCAL_SCAN_BASE_IMAGE}，开始构建（首次 5-10 分钟）"
  rotate_log "$SCAN_LOG"
  build_local_scan_base_image
}

ensure_scan_binary_available() {
  if [[ -x "$SCAN_DIST_BINARY" ]]; then
    return 0
  fi
  log "未找到 scan 二进制 ${SCAN_DIST_BINARY}，开始编译"
  start_heartbeat "编译 scan 二进制"
  local rc=0
  build_scan_binary || rc=$?
  stop_heartbeat
  if (( rc != 0 )); then
    tail_log_excerpt "scan" "$SCAN_LOG"
    return "$rc"
  fi
  return 0
}

ensure_selected_scan_image_available() {
  if [[ "$SCAN_IMAGE" != "$LOCAL_SCAN_IMAGE" ]]; then
    if docker_image_exists "$SCAN_IMAGE"; then
      ensure_scan_binary_available || return $?
      return 0
    fi
    log "scan 镜像 $SCAN_IMAGE 不在本地，尝试 docker pull"
    rotate_log "$SCAN_LOG"
    start_heartbeat "拉取 scan 镜像 $SCAN_IMAGE"
    local pull_rc=0
    docker_cmd pull "$SCAN_IMAGE" >>"$SCAN_LOG" 2>&1 || pull_rc=$?
    stop_heartbeat
    if (( pull_rc != 0 )); then
      log "拉取 scan 镜像失败: $SCAN_IMAGE"
      return 1
    fi
    ensure_scan_binary_available || return $?
    return 0
  fi

  # 本地镜像路径：app 存在则跳过整个构建链。
  if docker_image_exists "$LOCAL_SCAN_IMAGE"; then
    ensure_scan_binary_available || return $?
    return 0
  fi

  # App 不存在：需要 base 在场才能构建 app。
  ensure_scan_base_image_available || return $?

  log "未找到 scan 镜像 ${SCAN_IMAGE}，开始构建本地镜像"
  rotate_log "$SCAN_LOG"
  build_local_scan_image || return $?
  save_devctl_env
  ensure_scan_binary_available || return $?
}

run_scan_rebuild() {
  run_install 0 >/dev/null

  rotate_log "$SCAN_LOG"
  build_local_scan_image
  save_devctl_env
  ensure_scan_binary_available || fail "scan 二进制编译失败"
  stop_scan || true
  start_scan
  wait_for_scan_container 30 || {
    refresh_manifest
    tail_log_excerpt "scan" "$SCAN_LOG"
    fail "scan 容器在重建后未返回"
  }
  refresh_manifest
  log "scan 镜像已重建: $SCAN_IMAGE"
}

run_scan_rebuild_base() {
  run_install 0 >/dev/null

  rotate_log "$SCAN_LOG"
  log "强制重建 scan base 镜像（${LOCAL_SCAN_BASE_IMAGE}）"
  build_local_scan_base_image || fail "scan base 镜像构建失败"
  log "base 已重建，连带重建 app 镜像"
  build_local_scan_image || fail "scan 镜像构建失败"
  save_devctl_env
  ensure_scan_binary_available || fail "scan 二进制编译失败"
  stop_scan || true
  start_scan
  wait_for_scan_container 30 || {
    refresh_manifest
    tail_log_excerpt "scan" "$SCAN_LOG"
    fail "scan 容器在重建后未返回"
  }
  refresh_manifest
  log "scan base + app 镜像均已重建"
}

ghcr_load_conf() {
  GHCR_OWNER=""
  GHCR_TOKEN=""
  if [[ -f "$GHCR_CONFIG_FILE" ]]; then
    set +u
    # shellcheck disable=SC1090
    source "$GHCR_CONFIG_FILE"
    set -u
  fi
}

ghcr_require_conf() {
  ghcr_load_conf
  if [[ -z "${GHCR_OWNER:-}" || -z "${GHCR_TOKEN:-}" ]]; then
    fail "尚未配置 GHCR 凭据。

请先创建 ${GHCR_CONFIG_FILE}，内容形如：
  GHCR_OWNER=<your-github-username-or-org>
  GHCR_TOKEN=<github-classic-PAT-with-write:packages-scope>

然后限制权限：
  chmod 600 ${GHCR_CONFIG_FILE}

注意：要用 classic PAT，不是 fine-grained。
  打开 https://github.com/settings/tokens
  → 右上 'Generate new token' 下拉箭头 → 'Generate new token (classic)'
  → 勾 'write:packages' (read:packages 会自动带上)"
  fi
}

run_scan_publish_base() {
  local custom_tag=""
  local push_latest=1
  while (( $# > 0 )); do
    case "$1" in
      --tag)
        [[ -n "${2:-}" ]] || fail "--tag 需要参数"
        custom_tag="$2"
        shift 2
        ;;
      --no-latest)
        push_latest=0
        shift
        ;;
      *)
        fail "未知参数: $1。用法: ./devctl scan publish-base [--tag vX.Y] [--no-latest]"
        ;;
    esac
  done

  ghcr_require_conf

  if ! docker_image_exists "$LOCAL_SCAN_BASE_IMAGE"; then
    log "本地 base 镜像 $LOCAL_SCAN_BASE_IMAGE 不存在，先调用 build_local_scan_base_image 构建"
    build_local_scan_base_image || fail "scan base 镜像构建失败"
  fi

  local tag remote_repo remote_tagged remote_latest
  tag="${custom_tag:-$(date +v%Y.%m.%d-%H%M%S)}"
  remote_repo="${GHCR_REGISTRY}/${GHCR_OWNER}/${GHCR_BASE_REPO_NAME}"
  remote_tagged="${remote_repo}:${tag}"
  remote_latest="${remote_repo}:latest"

  log "登录 ${GHCR_REGISTRY}（用户 ${GHCR_OWNER}）"
  if ! printf '%s' "$GHCR_TOKEN" | docker_cmd login "$GHCR_REGISTRY" --username "$GHCR_OWNER" --password-stdin >/dev/null; then
    fail "GHCR 登录失败，请检查 $GHCR_CONFIG_FILE 中的 GHCR_OWNER / GHCR_TOKEN"
  fi

  log "打 tag：$LOCAL_SCAN_BASE_IMAGE → $remote_tagged"
  docker_cmd tag "$LOCAL_SCAN_BASE_IMAGE" "$remote_tagged" \
    || fail "docker tag 失败"

  log "推送 $remote_tagged"
  if ! docker_cmd push "$remote_tagged"; then
  fail "docker push 失败。如果是 unauthorized，确认 PAT 有 write:packages 权限；如果是 denied: requested access to the resource is denied，确认 GHCR_OWNER 拼写正确且首次推送已在 https://github.com/${GHCR_OWNER}?tab=packages 把 ${GHCR_BASE_REPO_NAME} 的可见性设为 public（或保持 private 但下次让节点能 pull）。"
  fi

  if (( push_latest )); then
    docker_cmd tag "$LOCAL_SCAN_BASE_IMAGE" "$remote_latest" \
      || fail "docker tag latest 失败"
    log "推送 $remote_latest"
    docker_cmd push "$remote_latest" || fail "docker push latest 失败"
  fi

  log "发布完成"
  log "  $remote_tagged"
  if (( push_latest )); then
    log "  $remote_latest"
  fi
  log "节点端拉取： docker pull $remote_latest"
}

run_scan_publish() {
  # 推送"完整" scan 镜像（base + tools + Go 二进制）到 GHCR。
  # 节点拉到这一个镜像就能直接跑，不再需要 SSH bind-mount 二进制。
  # 内部：build_scan_binary（交叉编译 linux/amd64）+ docker build -f dockerfile.release + tag + push
  local custom_tag=""
  local push_latest=1
  while (( $# > 0 )); do
    case "$1" in
      --tag)
        [[ -n "${2:-}" ]] || fail "--tag 需要参数"
        custom_tag="$2"
        shift 2
        ;;
      --no-latest)
        push_latest=0
        shift
        ;;
      *)
        fail "未知参数: $1。用法: ./devctl scan publish [--tag vX.Y] [--no-latest]"
        ;;
    esac
  done

  ghcr_require_conf

  # base 镜像必须先 publish 过。dockerfile.release 用 SCAN_BASE_IMAGE 作为 FROM。
  # 这里把 GHCR 上的 base latest 作为 build arg，确保和 publish-base 同源。
  local base_ref="${GHCR_REGISTRY}/${GHCR_OWNER}/${GHCR_BASE_REPO_NAME}:latest"
  if ! docker_image_exists "$base_ref"; then
    log "本地没有 ${base_ref}，先 docker pull"
    if ! docker_cmd pull "$base_ref" 2>>"$SCAN_LOG"; then
      fail "拉取 base 镜像失败。请先跑 ./devctl scan publish-base 推一次 base，再来跑 scan publish。"
    fi
  fi

  log "1/4 交叉编译 Go 二进制（linux/amd64）"
  rotate_log "$SCAN_LOG"
  start_heartbeat "build_scan_binary"
  local rc=0
  build_scan_binary || rc=$?
  stop_heartbeat
  if (( rc != 0 )); then
    tail_log_excerpt "scan" "$SCAN_LOG"
    fail "scan 二进制编译失败"
  fi
  [[ -x "$SCAN_DIST_BINARY" ]] || fail "二进制不在 ${SCAN_DIST_BINARY}"

  local tag remote_repo remote_tagged remote_latest local_image_tag
  tag="${custom_tag:-$(date +v%Y.%m.%d-%H%M%S)}"
  remote_repo="${GHCR_REGISTRY}/${GHCR_OWNER}/${GHCR_SCAN_REPO_NAME}"
  remote_tagged="${remote_repo}:${tag}"
  remote_latest="${remote_repo}:latest"
  local_image_tag="scopesentry-scan:${tag}"

  log "2/4 docker build -f dockerfile.release → ${local_image_tag}"
  start_heartbeat "docker build scan release"
  local build_rc=0
  (
    cd "$SCAN_DIR"
    DOCKER_BUILDKIT=1 "$DOCKER_BIN" build \
      -f dockerfile.release \
      --build-arg "SCAN_BASE_IMAGE=${base_ref}" \
      -t "$local_image_tag" \
      .
  ) >>"$SCAN_LOG" 2>&1 || build_rc=$?
  stop_heartbeat
  if (( build_rc != 0 )); then
    tail_log_excerpt "scan" "$SCAN_LOG"
    fail "docker build 失败，请查看 ${SCAN_LOG}"
  fi

  log "3/4 登录 ${GHCR_REGISTRY}（用户 ${GHCR_OWNER}）"
  if ! printf '%s' "$GHCR_TOKEN" | docker_cmd login "$GHCR_REGISTRY" --username "$GHCR_OWNER" --password-stdin >/dev/null; then
    fail "GHCR 登录失败，请检查 ${GHCR_CONFIG_FILE}"
  fi

  docker_cmd tag "$local_image_tag" "$remote_tagged" || fail "docker tag 失败"
  log "4/4 推送 ${remote_tagged}"
  if ! docker_cmd push "$remote_tagged"; then
    fail "docker push 失败。首次推送后到 https://github.com/${GHCR_OWNER}?tab=packages 把 ${GHCR_SCAN_REPO_NAME} 设为 public。"
  fi
  if (( push_latest )); then
    docker_cmd tag "$local_image_tag" "$remote_latest" || fail "docker tag latest 失败"
    log "推送 ${remote_latest}"
    docker_cmd push "$remote_latest" || fail "docker push latest 失败"
  fi

  log "完整 scan 镜像发布完成"
  log "  ${remote_tagged}"
  if (( push_latest )); then
    log "  ${remote_latest}"
  fi
  log "节点端更新："
  log "  curl -fsSL https://raw.githubusercontent.com/${GHCR_OWNER}/<repo>/main/scripts/update-node.sh | bash"
}

run_scan_reload() {
  ensure_local_dirs
  if ! docker_container_running "$SCAN_CONTAINER_NAME"; then
    fail "scan 容器未运行，请先运行 ./devctl up 或 ./devctl scan rebuild"
  fi

  stage_set_total 2
  stage_begin "build" "交叉编译 Go 二进制"
  rotate_log "$SCAN_LOG"
  start_heartbeat "编译 scan 二进制"
  local rc=0
  build_scan_binary || rc=$?
  stop_heartbeat
  if (( rc != 0 )); then
    tail_log_excerpt "scan" "$SCAN_LOG"
    fail "scan 二进制编译失败"
  fi
  stage_end "build"

  stage_begin "restart" "重启 scan 容器"
  docker_cmd restart "$SCAN_CONTAINER_NAME" >>"$SCAN_LOG" 2>&1 \
