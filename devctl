build_server_binary() {
  local force_clean_rebuild="${1:-0}"
  local -a build_cmd
  ensure_local_dirs
  load_server_env_values

  local go_cache_dir go_mod_cache_dir
  go_cache_dir="$CACHE_DIR/go-build/scope-sentry"
  go_mod_cache_dir="$CACHE_DIR/go-mod"

  mkdir -p "$go_cache_dir" "$go_mod_cache_dir" "$SERVER_RUNTIME_DIR"
  if (( force_clean_rebuild )); then
    rm -rf "$go_cache_dir"
    mkdir -p "$go_cache_dir"
    rm -f "$SERVER_BINARY"
  fi
  build_cmd=("$GO_BIN" build -o "$SERVER_BINARY" ./cmd/main)
  if (( force_clean_rebuild )); then
    build_cmd=("$GO_BIN" build -a -o "$SERVER_BINARY" ./cmd/main)
  fi
  (
    cd "$SERVER_DIR"
    GOCACHE="$go_cache_dir" \
    GOMODCACHE="$go_mod_cache_dir" \
    "${build_cmd[@]}"
  ) >>"$SERVER_LOG" 2>&1

  record_current_server_embed_meta >>"$SERVER_LOG" 2>&1
}

start_server() {
  local status
  local server_pid
  local rebuild_reason=""
  local force_clean_rebuild=0
  status="$(server_status)"
  rebuild_reason="$(server_rebuild_reason 2>/dev/null || true)"

  if [[ -n "$rebuild_reason" ]]; then
    force_clean_rebuild=1
    log "server: ${rebuild_reason}，强制净重编后端"
    if [[ "$status" == "running" || "$status" == "starting" ]]; then
      stop_local_process_by_port_or_pid "$SERVER_PID_FILE" "scope-sentry-dev" "$(url_port "$API_URL" 8080)" 1
      status="stopped"
    fi
  elif [[ "$status" == "running" || "$status" == "starting" ]]; then
    return 0
  fi

  rotate_log "$SERVER_LOG"
  start_heartbeat "编译后端二进制"
  local build_rc=0
  build_server_binary "$force_clean_rebuild" || build_rc=$?
  stop_heartbeat
  if (( build_rc != 0 )); then
    return "$build_rc"
  fi

  load_server_env_values
  server_pid="$("$PYTHON_BIN" - \
    "$SERVER_DIR" \
    "$SERVER_LOG" \
    "$SERVER_BINARY" \
    "$SERVER_TIMEZONE_VALUE" \
    "$SERVER_MONGODB_IP_VALUE" \
    "$SERVER_MONGODB_PORT_VALUE" \
    "$SERVER_MONGODB_DATABASE_VALUE" \
    "$SERVER_MONGODB_USER_VALUE" \
    "$SERVER_MONGODB_PASSWORD_VALUE" \
    "$SERVER_REDIS_IP_VALUE" \
    "$SERVER_REDIS_PORT_VALUE" \
    "$SERVER_REDIS_PASSWORD_VALUE" <<'PY'
import os
import subprocess
import sys

(
    server_dir,
    log_path,
    server_binary,
    timezone,
    mongodb_ip,
    mongodb_port,
    mongodb_database,
    mongodb_user,
    mongodb_password,
    redis_ip,
    redis_port,
    redis_password,
) = sys.argv[1:13]

env = os.environ.copy()
env.update(
    {
        "TIMEZONE": timezone,
        "MONGODB_IP": mongodb_ip,
        "MONGODB_PORT": mongodb_port,
        "MONGODB_DATABASE": mongodb_database,
        "MONGODB_USER": mongodb_user,
        "MONGODB_PASSWORD": mongodb_password,
        "MONGODB_DIRECT_CONNECTION": os.environ.get("MONGODB_DIRECT_CONNECTION", "true"),
        "REDIS_IP": redis_ip,
        "REDIS_PORT": redis_port,
        "REDIS_PASSWORD": redis_password,
    }
)

with open(log_path, "a", encoding="utf-8") as log_file:
    proc = subprocess.Popen(
        [server_binary],
        cwd=server_dir,
        env=env,
        stdin=subprocess.DEVNULL,
        stdout=log_file,
        stderr=subprocess.STDOUT,
        start_new_session=True,
        text=True,
    )

print(proc.pid, end="")
PY
)"
  printf '%s' "$server_pid" >"$SERVER_PID_FILE"
}

start_ui() {
