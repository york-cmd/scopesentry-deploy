remove_stale_db_container() {
  local container="$1"
  local state status dead
  state="$(docker_container_state "$container")"
  [[ -n "$state" ]] || return 0

  status="${state%% *}"
  dead="${state##* }"
  if [[ "$status" == "dead" || "$status" == "removing" || "$dead" == "true" ]]; then
    log "移除异常数据库容器: $container (status=$status dead=$dead)"
    docker_cmd rm -f "$container" >>"$DB_LOG" 2>&1 || true
  fi
}

