  wait_for_scan_container 30 "restart" \
    || fail "scan 容器在重启后未返回运行状态"
  stage_end "restart"
  refresh_manifest
  log "scan 已热加载（二进制已刷新）"
}

build_server_prod_binary() {
  # 构建 server 生产二进制：pnpm build:pro + 同步 UI 到 cmd/main/static + Go 交叉编译 linux/amd64。
  # 输出到 $SERVER_DIST_BINARY，dockerfile 直接 COPY 这个二进制。
  rotate_log "$SERVER_LOG"

  log "  - pnpm build:pro + 同步 UI 到 cmd/main/static（调用 dev-sync-ui-static.sh）"
  start_heartbeat "前端打包 + UI 同步"
  local sync_rc=0
  bash "$SCRIPTS_DIR/dev-sync-ui-static.sh" >>"$SERVER_LOG" 2>&1 || sync_rc=$?
  stop_heartbeat
  (( sync_rc == 0 )) || {
    tail_log_excerpt "server" "$SERVER_LOG"
    fail "前端打包或同步失败，请查看 $SERVER_LOG"
  }

  log "  - Go 交叉编译 linux/amd64 (CGO_ENABLED=0) → $SERVER_DIST_BINARY"
  mkdir -p "$SERVER_DIST_DIR"
  local go_cache_dir go_mod_cache_dir
  go_cache_dir="$CACHE_DIR/go-build/scope-sentry-prod"
  go_mod_cache_dir="$CACHE_DIR/go-mod"
  mkdir -p "$go_cache_dir" "$go_mod_cache_dir"
  start_heartbeat "Go 交叉编译 linux/amd64"
  local build_rc=0
  (
    cd "$SERVER_DIR"
    GOOS=linux GOARCH=amd64 CGO_ENABLED=0 \
    GOCACHE="$go_cache_dir" GOMODCACHE="$go_mod_cache_dir" \
    "$GO_BIN" build -trimpath -ldflags="-s -w" -o "$SERVER_DIST_BINARY" ./cmd/main
  ) >>"$SERVER_LOG" 2>&1 || build_rc=$?
  stop_heartbeat
  (( build_rc == 0 )) || {
    tail_log_excerpt "server" "$SERVER_LOG"
    fail "Go 交叉编译失败，请查看 $SERVER_LOG"
  }
}

run_server_publish() {
  # 构建 + 推送 server 镜像到 GHCR。
  # 复用 build_server_prod_binary（pnpm build:pro + embed UI + 交叉编译）。
  # 镜像本体由 ScopeSentry/dockerfile 在本地 docker build 出来，
  # 与 deploy push 不同——deploy push 是在远端 build，这里是 dev 机 build 后推 registry。
  local custom_tag=""
  local push_latest=1
  while (( $# > 0 )); do
    case "$1" in
      --tag)
        [[ -n "${2:-}" ]] || fail "--tag 需要参数"
        custom_tag="$2"
        shift 2
        ;;
      --no-latest)
        push_latest=0
        shift
        ;;
      *)
        fail "未知参数: $1。用法: ./devctl server publish [--tag vX.Y] [--no-latest]"
        ;;
    esac
  done

  ghcr_require_conf

  log "1/4 构建 server prod 二进制（pnpm build:pro + embed UI + 交叉编译）"
  build_server_prod_binary
  [[ -x "$SERVER_DIST_BINARY" ]] || fail "二进制不在 ${SERVER_DIST_BINARY}"

  local local_image_tag="$DEPLOY_SERVER_IMAGE"
  log "2/4 本地 docker build → ${local_image_tag}"
  rotate_log "$SERVER_LOG"
  start_heartbeat "本地 docker build server 镜像"
  local build_rc=0
  (
    cd "$SERVER_DIR"
    DOCKER_BUILDKIT=1 "$DOCKER_BIN" build -f dockerfile -t "$local_image_tag" .
  ) >>"$SERVER_LOG" 2>&1 || build_rc=$?
  stop_heartbeat
  (( build_rc == 0 )) || {
    tail_log_excerpt "server" "$SERVER_LOG"
    fail "docker build 失败，请查看 ${SERVER_LOG}"
  }

  local tag remote_repo remote_tagged remote_latest
  tag="${custom_tag:-$(date +v%Y.%m.%d-%H%M%S)}"
  remote_repo="${GHCR_REGISTRY}/${GHCR_OWNER}/${GHCR_SERVER_REPO_NAME}"
  remote_tagged="${remote_repo}:${tag}"
  remote_latest="${remote_repo}:latest"

  log "3/4 登录 ${GHCR_REGISTRY}（用户 ${GHCR_OWNER}）"
  if ! printf '%s' "$GHCR_TOKEN" | docker_cmd login "$GHCR_REGISTRY" --username "$GHCR_OWNER" --password-stdin >/dev/null; then
    fail "GHCR 登录失败，请检查 ${GHCR_CONFIG_FILE}"
  fi

  log "打 tag：${local_image_tag} → ${remote_tagged}"
  docker_cmd tag "$local_image_tag" "$remote_tagged" \
    || fail "docker tag 失败"

  log "4/4 推送 ${remote_tagged}"
  if ! docker_cmd push "$remote_tagged"; then
    fail "docker push 失败。如果是 denied/unauthorized，确认 PAT 有 write:packages 权限；首次推送后需要在 https://github.com/${GHCR_OWNER}?tab=packages 把 ${GHCR_SERVER_REPO_NAME} 设为 public（或保持 private 但目标机要 docker login）。"
  fi

  if (( push_latest )); then
    docker_cmd tag "$local_image_tag" "$remote_latest" \
      || fail "docker tag latest 失败"
    log "推送 ${remote_latest}"
    docker_cmd push "$remote_latest" || fail "docker push latest 失败"
  fi

  log "发布完成"
  log "  ${remote_tagged}"
  if (( push_latest )); then
    log "  ${remote_latest}"
  fi
  log "目标机器一键安装（先把 scripts/install-server.sh 推到你 fork 的 main）："
  log "  curl -fsSL https://raw.githubusercontent.com/${GHCR_OWNER}/<repo-name>/main/scripts/install-server.sh | bash"
}

run_publish_all() {
  local custom_tag=""
  local skip_base=0
  local force_base=0
  local skip_git=0

  while (( $# > 0 )); do
    case "$1" in
      --tag)
        [[ -n "${2:-}" ]] || fail "--tag 需要参数"
        custom_tag="$2"
        shift 2
        ;;
      --skip-base)
        skip_base=1
        shift
        ;;
      --force-base)
        force_base=1
        shift
        ;;
      --skip-git)
        skip_git=1
        shift
        ;;
      --help|-h)
        cat <<HELP
用法：./devctl publish-all [--tag vX.Y] [--skip-base] [--force-base] [--skip-git]

行为（4 步串行，fail-fast）：
  1. 检查 ScopeSentry-Scan/dockerfile.base sha256 指纹：与上次成功 publish-base 不同
     或显式 --force-base 时，重新跑 scan publish-base；否则跳过。
  2. server publish
  3. scan publish
  4. 工作区有未提交改动且未指定 --skip-git 时：
     git add -A && git commit -m "publish-all <tag>" && git push origin main

所有 publish 共用同一时间戳 tag，默认 v\$(date +%Y.%m.%d-%H%M%S)。
状态文件：${STATE_DIR}/scan-base-fingerprint
HELP
        return 0
        ;;
      *)
        fail "未知参数: $1。用法: ./devctl publish-all [--tag vX.Y] [--skip-base] [--force-base] [--skip-git]"
        ;;
    esac
  done

  local tag="${custom_tag:-$(date +v%Y.%m.%d-%H%M%S)}"
  log "publish-all 启动（tag=${tag}）"

  mkdir -p "$STATE_DIR"
  local fingerprint_file="$STATE_DIR/scan-base-fingerprint"
  local dockerfile_base="$SCAN_DIR/dockerfile.base"

  if (( skip_base == 1 )); then
    log "步骤 1/4：--skip-base，跳过 scan-base"
  else
    [[ -f "$dockerfile_base" ]] || fail "找不到 $dockerfile_base"
    local current_fp expected_fp
    if command -v sha256sum >/dev/null 2>&1; then
      current_fp="$(sha256sum "$dockerfile_base" | awk '{print $1}')"
    elif command -v shasum >/dev/null 2>&1; then
      current_fp="$(shasum -a 256 "$dockerfile_base" | awk '{print $1}')"
    else
      fail "找不到 sha256sum 或 shasum，无法计算 dockerfile.base 指纹"
    fi
    expected_fp="$(cat "$fingerprint_file" 2>/dev/null || echo "")"
    if (( force_base == 1 )) || [[ "$current_fp" != "$expected_fp" ]]; then
      if (( force_base == 1 )); then
        log "步骤 1/4：--force-base，强制重新 publish-base"
      else
        log "步骤 1/4：scan-base 指纹变化，重新 publish-base"
      fi
      run_scan_publish_base --tag "$tag"
      echo "$current_fp" > "$fingerprint_file"
    else
      log "步骤 1/4：scan-base 未变化，跳过 publish-base"
    fi
  fi

  log "步骤 2/4：publish server"
  run_server_publish --tag "$tag"

  log "步骤 3/4：publish scan"
  run_scan_publish --tag "$tag"

  if (( skip_git == 1 )); then
    log "步骤 4/4：--skip-git，跳过 git 同步"
  else
    local has_dirty=0 ahead_count=0
    if [[ -n "$(cd "$ROOT_DIR" && git status --porcelain 2>/dev/null)" ]]; then
      has_dirty=1
    fi
    ( cd "$ROOT_DIR" && git fetch origin main 2>/dev/null ) || true
    ahead_count="$(cd "$ROOT_DIR" && git rev-list --count origin/main..HEAD 2>/dev/null || echo 0)"

    if (( has_dirty == 1 )); then
      log "步骤 4/4：工作区有改动，git add -A && commit && push origin main"
      ( cd "$ROOT_DIR" \
        && git add -A \
        && git commit -m "publish-all ${tag}" \
        && git push origin main )
    elif (( ahead_count > 0 )); then
      log "步骤 4/4：本地领先 origin/main ${ahead_count} 个 commit，git push origin main"
      ( cd "$ROOT_DIR" && git push origin main )
    else
      log "步骤 4/4：工作区干净且与 origin/main 同步，无需 push"
    fi
  fi

  log "publish-all 完成（tag=${tag}）"
}

run_update() {
  run_install 0 >/dev/null
  start_heartbeat "更新 UI 依赖（pnpm install）"
  local pnpm_rc=0
  (
    cd "$UI_DIR"
    "$PNPM_BIN" install >>"$UI_LOG" 2>&1
  ) || pnpm_rc=$?
  stop_heartbeat
  if (( pnpm_rc != 0 )); then
    fail "更新期间 pnpm install 失败，请查看 $UI_LOG"
  fi
  stop_local_process_by_port_or_pid "$SERVER_PID_FILE" "scope-sentry-dev" "$(url_port "$API_URL" 8080)" 1
  stop_local_process_by_port_or_pid "$UI_PID_FILE" "pnpm" "$(url_port "$UI_URL" 4000)" 0
  start_db
  wait_for_mongo_ready 90 || fail "更新期间 mongodb 未就绪"
  wait_for_tcp_port 127.0.0.1 "${SCAN_REDIS_PORT:-6379}" 30 || fail "更新期间 redis 端口不可达"
  start_server
  if wait_for_http "$API_URL" 60 "" "$SERVER_PID_FILE" "scope-sentry-dev"; then
    :
  else
    local wait_status=$?
    if [[ "$wait_status" == "2" ]]; then
      fail "更新期间后端进程在就绪检查前退出"
    fi
    fail "更新期间后端未就绪"
  fi
  local embedded_ui_error=""
  if embedded_ui_error="$(verify_server_embedded_ui_consistent "$API_URL")"; then
    :
  else
    printf '%s\n' "$embedded_ui_error" >>"$SERVER_LOG"
    stop_local_process_by_port_or_pid "$SERVER_PID_FILE" "scope-sentry-dev" "$(url_port "$API_URL" 8080)" 1
    refresh_manifest
    fail "更新期间后端嵌入前端校验失败：$embedded_ui_error"
  fi
  start_ui
  if wait_for_http "$UI_URL" 60 "" "$UI_PID_FILE" "pnpm"; then
    :
  else
    local wait_status=$?
    if [[ "$wait_status" == "2" ]]; then
      fail "更新期间 UI 进程在就绪检查前退出"
    fi
    fail "更新期间 UI 未就绪"
  fi
  run_scan_rebuild
  refresh_manifest
  log "本地开发环境已更新"
}

clean_dir_contents() {
  local dir="$1"
  [[ -d "$dir" ]] || return 0
  find "$dir" -mindepth 1 -maxdepth 1 -exec rm -rf {} +
}

run_clean() {
  ensure_local_dirs
  clean_dir_contents "$LOG_DIR"
  clean_dir_contents "$PID_DIR"
  clean_dir_contents "$CACHE_DIR"
  clean_dir_contents "$TMP_RUNTIME_DIR"
  refresh_manifest
  log "临时文件已清理"
}

run_uninstall() {
  local purge="${1:-0}"
  run_down >/dev/null 2>&1 || true
  rm -rf "$LOCAL_DEV_DIR"
  if [[ "$purge" == "1" ]]; then
    rm -rf \
      "$SERVER_DIR/data/mongodb" \
      "$SERVER_DIR/data/redis"
  fi
  log "本地开发运行时已移除"
}

run_logs() {
  local target="${1:-}"
  case "$target" in
    server)
      exec tail -n 200 -f "$SERVER_LOG"
      ;;
    ui)
      exec tail -n 200 -f "$UI_LOG"
      ;;
    scan)
      exec docker_cmd logs --tail 200 -f "$SCAN_CONTAINER_NAME"
      ;;
    db)
      exec db_compose logs -f mongodb redis
      ;;
    *)
      fail "用法: ./devctl logs server|ui|scan|db"
      ;;
  esac
}

main() {
  local command="${1:-status}"
  shift || true

  case "$command" in
    install)
      local force=0
      if [[ "${1:-}" == "--force" ]]; then
        force=1
      fi
      run_install "$force"
      ;;
    doctor)
      run_doctor
      ;;
    up)
      run_up
      ;;
    down)
      run_down
      ;;
    restart)
      log "===== 重启：停机阶段 ====="
      run_down
      log "===== 重启：启动阶段 ====="
      run_up
      ;;
    status)
      print_status
      ;;
    logs)
      run_logs "${1:-}"
      ;;
    reset-password)
      reset_local_web_password "${1:-}"
      ;;
    update)
      run_update
      ;;
    scan)
      case "${1:-}" in
        reload)
          run_scan_reload
          ;;
        rebuild)
          run_scan_rebuild
          ;;
        rebuild-base)
          run_scan_rebuild_base
          ;;
        publish-base)
          shift
          run_scan_publish_base "$@"
          ;;
        publish)
          shift
          run_scan_publish "$@"
          ;;
        *)
          fail "用法: ./devctl scan reload|rebuild|rebuild-base|publish-base|publish"
          ;;
      esac
      ;;
    server)
      case "${1:-}" in
        publish)
          shift
          run_server_publish "$@"
          ;;
        *)
          fail "用法: ./devctl server publish [--tag vX.Y] [--no-latest]"
          ;;
      esac
      ;;
    publish-all)
      run_publish_all "$@"
      ;;
    deploy)
      fail "deploy 子命令已移除。请改用 ./devctl scan publish / server publish 推 GHCR，然后到目标机器跑 scripts/install-{node,server}.sh。详见 DEPLOY_SERVER.md / DEPLOY_NODE.md。"
      ;;
    clean)
      run_clean
      ;;
    uninstall)
      local purge=0
      if [[ "${1:-}" == "--purge" ]]; then
        purge=1
      fi
      run_uninstall "$purge"
      ;;
    help|-h|--help)
      usage
      ;;
    *)
      usage
      exit 1
      ;;
  esac
}

main "$@"
