log() {
  printf '[devctl] %s\n' "$*"
}

# ---- 阶段计数 ----
STAGE_TOTAL=0
STAGE_CURRENT=0
STAGE_TIMER=0

stage_set_total() {
  STAGE_TOTAL="$1"
  STAGE_CURRENT=0
}

stage_begin() {
  local stage_id="$1"
  local label_cn="$2"
  STAGE_CURRENT=$((STAGE_CURRENT + 1))
  STAGE_TIMER="$(date +%s)"
  log "[${STAGE_CURRENT}/${STAGE_TOTAL}] 阶段 ${stage_id}: ${label_cn}"
}

stage_end() {
  local stage_id="$1"
  local elapsed=$(( $(date +%s) - STAGE_TIMER ))
  log "[${STAGE_CURRENT}/${STAGE_TOTAL}] 阶段 ${stage_id}: 就绪（用时 ${elapsed}s）"
}

# ---- 以下三个保留函数签名（内部使用），文案改为中文 ----
log_stage_start() {
  local stage="$1"
  local message="$2"
  log "阶段 ${stage}: ${message}"
}

log_stage_ready() {
  local stage="$1"
  local elapsed_seconds="$2"
  log "阶段 ${stage}: 就绪（用时 ${elapsed_seconds}s）"
}

shell_quote() {
