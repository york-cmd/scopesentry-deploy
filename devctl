  [[ -f "$DB_COMPOSE_FILE" ]] || missing+=("$DB_COMPOSE_FILE")
  [[ -f "$SCAN_COMPOSE_FILE" ]] || missing+=("$SCAN_COMPOSE_FILE")

  if (( ${#missing[@]} == 0 )); then
    doctor_pass "repo_layout" "必需的项目目录与 compose 文件齐全"
  else
    doctor_fail "repo_layout" "缺失路径：${missing[*]}"
    doctor_hint "请在仓库根目录下运行，并补全缺失的项目目录"
  fi
}

doctor_check_path() {
  local check_name="$1"
  local path="$2"
  local path_type="$3"
  local severity="${4:-fail}"
  local hint="${5:-}"
  local exists=1

  case "$path_type" in
    file)
      [[ -f "$path" ]] || exists=0
      ;;
    dir)
      [[ -d "$path" ]] || exists=0
      ;;
    *)
      exists=0
      ;;
  esac

  if [[ "$exists" == "1" ]]; then
    doctor_pass "$check_name" "$path_type 存在：$path"
    return 0
  fi

  if [[ "$severity" == "warn" ]]; then
    doctor_warn "$check_name" "$path_type 缺失：$path"
  else
    doctor_fail "$check_name" "$path_type 缺失：$path"
  fi
  [[ -n "$hint" ]] && doctor_hint "$hint"
}

doctor_check_scan_network_mode() {
  local compose_file="$ROOT_DIR/scripts/dev-scan-docker-compose.yml"

  if [[ ! -f "$compose_file" ]]; then
    doctor_warn "scan_network_mode" "未找到本地 scan compose：$compose_file"
    doctor_hint "缺少 scripts/dev-scan-docker-compose.yml，无法判断 masscan 网络模式"
    return 0
  fi

  if grep -Eq '^[[:space:]]*network_mode:[[:space:]]*host([[:space:]]|$)' "$compose_file"; then
    doctor_pass "scan_network_mode" "本地 scan 容器使用 host 网络"
    return 0
  fi

  doctor_warn "scan_network_mode" "本地 scan 容器未使用 host 网络，masscan 在 Docker Desktop/bridge 模式下可能漏扫"
  doctor_hint "如需验证 masscan 结果，优先使用 Linux host 网络扫描节点；本地 dev 更适合验证插件集成与流程"
}

